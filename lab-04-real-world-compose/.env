# ============================================================
# Environment variables for Lab 04 — Task Manager
# ============================================================
# This file is loaded by Docker Compose via the "env_file"
# directive. The variables defined here are injected into
# the containers that reference this file.
#
# Both the "api" and "db" services use this file:
#   - PostgreSQL (db) reads these to create the database and user.
#   - Flask (api) reads these to connect to the database.
#
# In a real project, this file should be added to .gitignore
# so that secrets (like passwords) are never committed to
# version control. For this lab we include it for convenience.
# ============================================================

POSTGRES_DB=taskmanager
POSTGRES_USER=admin
POSTGRES_PASSWORD=secretpassword
